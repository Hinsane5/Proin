# Copy to .env and fill in. NEVER commit real secrets.

# Database (Postgres). Use a pooled URL for the app, direct URL for migrations.
DATABASE_URL="postgresql://user:password@localhost:5432/marketplace?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/marketplace?schema=public"

# Auth.js (NextAuth v5)
AUTH_SECRET="generate-with: openssl rand -base64 32"
# OAuth provider example (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Stripe (use test keys locally)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
